# Rentora — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file

# ============================================
# FIREBASE (Client-Side — Safe to Expose)
# ============================================
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000:web:abcdef123456
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================
# PAYSTACK (Client-Side — Public Key Only)
# ============================================
VITE_PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key

# ============================================
# SEED DATA (Development Only)
# ============================================
VITE_SEED_ADMIN_PASSWORD=your_admin_seed_password
VITE_SEED_USER_PASSWORD=your_user_seed_password

# ============================================
# FIREBASE ADMIN (Server-Side Only — SECRET)
# Set these in Vercel Dashboard, NOT in .env
# ============================================
# FIREBASE_PROJECT_ID=your_project_id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ============================================
# PAYSTACK (Server-Side Only — SECRET)
# Set this in Vercel Dashboard, NOT in .env
# ============================================
# PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key

# ============================================
# NOTES
# ============================================
# - VITE_ prefixed vars are exposed to the frontend (safe for public keys)
# - Non-VITE_ vars are server-only (for API routes and Cloud Functions)
# - Server secrets should ONLY be set in Vercel Dashboard or functions/.env
# - Never commit actual secret values to git
