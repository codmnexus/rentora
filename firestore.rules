rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helper functions ----
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      // NOTE: For production, use Firebase Auth Custom Claims instead:
      // return isAuthenticated() && request.auth.token.admin == true;
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function isLandlord() {
      return isAuthenticated() && getUserRole() == 'landlord';
    }

    // ---- Users ----
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      // Users can only update safe fields — block role/verified/banned self-escalation
      allow update: if isOwner(userId) && (
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['role', 'verified', 'banned', 'emailVerified'])
      ) || isAdmin();
      allow delete: if isAdmin();
    }

    // ---- Properties ----
    match /properties/{propertyId} {
      allow read: if true;
      allow create: if isAuthenticated() && (isLandlord() || isAdmin())
        && request.resource.data.keys().hasAll(['title', 'type', 'area', 'price'])
        && request.resource.data.title is string
        && request.resource.data.price is number
        && request.resource.data.price > 0;
      allow update: if isAuthenticated() && (
        resource.data.landlordId == request.auth.uid || isAdmin()
      );
      allow delete: if isAuthenticated() && (
        resource.data.landlordId == request.auth.uid || isAdmin()
      );
    }

    // ---- Takeovers ----
    match /takeovers/{takeoverId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.resource.data.keys().hasAll(['title', 'rent', 'area'])
        && request.resource.data.rent is number;
      allow update: if isAuthenticated() && (
        resource.data.studentId == request.auth.uid || isAdmin()
      );
      allow delete: if isAuthenticated() && (
        resource.data.studentId == request.auth.uid || isAdmin()
      );
    }

    // ---- Messages ----
    match /messages/{messageId} {
      allow read: if isAuthenticated() && (
        resource.data.senderId == request.auth.uid ||
        resource.data.receiverId == request.auth.uid
      );
      allow create: if isAuthenticated() &&
        request.resource.data.senderId == request.auth.uid &&
        request.resource.data.message is string &&
        request.resource.data.message.size() <= 2000;
      allow update, delete: if false;
    }

    // ---- Saved Listings ----
    match /saved/{savedId} {
      allow read: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    // ---- Inspections ----
    match /inspections/{inspectionId} {
      allow read: if isAuthenticated() && (
        resource.data.tenantId == request.auth.uid ||
        resource.data.landlordId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuthenticated()
        && request.resource.data.keys().hasAll(['tenantId', 'propertyId', 'date', 'time']);
      allow update: if isAuthenticated() && (
        resource.data.landlordId == request.auth.uid || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ---- Reviews ----
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.rating is number &&
        request.resource.data.rating >= 1 &&
        request.resource.data.rating <= 5;
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
    }

    // ---- Reports ----
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated()
        && request.resource.data.keys().hasAll(['reporterId', 'targetId', 'reason'])
        && request.resource.data.reason is string;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ---- Notifications ----
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['read']);
      allow delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }
  }
}
